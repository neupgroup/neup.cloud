generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model Server {
  id           String    @id @db.Text
  name         String    @db.Text
  username     String    @db.Text
  type         String    @db.Text
  provider     String    @db.Text
  ram          String?   @db.Text
  storage      String?   @db.Text
  publicIp     String    @map("publicIp") @db.Text
  privateIp    String?   @map("privateIp") @db.Text
  privateKey   String?   @map("privateKey") @db.Text
  proxyHandler String?   @map("proxyHandler") @db.Text
  loadBalancer String?   @map("loadBalancer") @db.Text
  createdAt    DateTime  @map("createdAt") @db.Timestamp(6)
  updatedAt    DateTime  @map("updatedAt") @db.Timestamp(6)

  @@map("servers")
}

model ServerLog {
  id          String   @id @db.Text
  serverId    String   @map("serverId") @db.Text
  command     String   @db.Text
  commandName String?  @map("commandName") @db.Text
  output      String?  @db.Text
  status      String   @db.Text
  runAt       DateTime @map("runAt") @db.Timestamp(6)

  @@map("server_logs")
}

model SavedCommand {
  id           String   @id @db.Text
  name         String   @db.Text
  command      String   @db.Text
  description  String?  @db.Text
  nextCommands String[] @default([])
  variables    Json?
  createdAt    DateTime @map("createdAt") @db.Timestamp(6)
  updatedAt    DateTime @map("updatedAt") @db.Timestamp(6)

  @@map("saved_commands")
}

model Application {
  id            String   @id @db.Text
  name          String   @db.Text
  location      String   @db.Text
  language      String   @db.Text
  repository    String?  @db.Text
  networkAccess String[] @default([])
  commands      Json?
  information   Json?
  owner         String   @db.Text
  createdAt     DateTime @map("createdAt") @db.Timestamp(6)
  updatedAt     DateTime @map("updatedAt") @db.Timestamp(6)
  environments  Json?
  files         Json?

  @@map("applications")
}

model Domain {
  id               String   @id @db.Text
  name             String   @unique @db.Text
  status           String   @db.Text
  addedAt          DateTime @map("addedAt") @db.Timestamp(6)
  verificationCode String?  @map("verificationCode") @db.Text
  verified         Boolean

  @@map("domains")
}

model EnvironmentVariable {
  id              String   @id @db.Text
  key             String   @db.Text
  value           String   @db.Text
  targetType      String   @map("targetType") @db.Text
  selectedTargets String[] @map("selectedTargets") @default([])
  isConfidential  Boolean  @map("isConfidential")
  protectValue    Boolean  @map("protectValue")
  createdAt       DateTime @map("createdAt") @db.Timestamp(6)

  @@map("environment_variables")
}

model AppError {
  id        String   @id @db.Text
  message   String   @db.Text
  level     String   @db.Text
  source    String   @db.Text
  timestamp DateTime @db.Timestamp(6)
  stack     String?  @db.Text

  @@map("errors")
}

model CommandSet {
  id          String   @id @db.Text
  userId      String   @map("userId") @db.Text
  name        String   @db.Text
  description String?  @db.Text
  commands    Json
  createdAt   DateTime @map("createdAt") @db.Timestamp(6)

  @@map("command_sets")
}

model WebService {
  id         String    @id @db.Text
  name       String?   @db.Text
  type       String    @db.Text
  createdOn  DateTime  @map("created_on") @db.Timestamp(6)
  updatedOn  DateTime? @map("updated_on") @db.Timestamp(6)
  createdBy  String    @map("created_by") @db.Text
  value      Json
  serverId   String?   @map("serverId") @db.Text
  serverName String?   @map("serverName") @db.Text

  @@map("webservices")
}

model NginxConfiguration {
  serverId        String    @id @map("serverId") @db.Text
  serverIp        String    @map("serverIp") @db.Text
  configName      String    @map("configName") @db.Text
  blocks          Json
  domainRedirects Json?
  updatedAt       DateTime  @map("updatedAt") @db.Timestamp(6)

  @@map("nginx_configurations")
}

model LiveSession {
  id          String   @id @db.Text
  createdAt   DateTime @map("createdAt") @db.Timestamp(6)
  cwd         String   @db.Text
  status      String   @db.Text
  history     Json
  serverLogId String?  @map("serverLogId") @db.Text
  serverId    String?  @map("serverId") @db.Text

  @@map("live_sessions")
}

model AccessToken {
  id        BigInt @id @default(autoincrement())
  accountId String @map("account_id") @db.Text
  name      String @db.Text
  key       String @map("key") @db.Text

  @@map("accessTokens")
}

model IntelligenceModel {
  id                BigInt @id @default(autoincrement())
  title             String @db.Text
  provider          String @db.Text
  model             String @db.Text
  description       String? @db.Text
  currency          String @default("USD") @db.Text
  rate              String @default("0/1000") @db.Text
  costPer1000Tokens Float  @map("costPer1000Tokens")
  inputPrice        Float  @map("inputPrice")
  outputPrice       Float  @map("outputPrice")
  price             Json

  @@unique([provider, model], map: "intelligence_models_provider_model_unique")
  @@map("intelligence_models")
}

model IntelligenceAccess {
  id                 BigInt  @id @default(autoincrement())
  promptId           String  @map("prompt_id") @db.Text
  accountId          String  @map("account_id") @db.Text
  tokenHash          String  @map("token_hash") @db.Text
  model              String? @db.Text
  primaryModel       String? @map("primaryModel") @db.Text
  fallbackModel      String? @map("fallbackModel") @db.Text
  maxTokens          Int?    @map("maxTokens")
  defPrompt          String? @map("defPrompt") @db.Text
  balance            Float
  primaryAccessKey   BigInt? @map("primaryAccessKey")
  fallbackAccessKey  BigInt? @map("fallbackAccessKey")
  primaryModelConfig Json?   @map("primaryModelConfig")
  fallbackModelConfig Json?  @map("fallbackModelConfig")

  @@unique([accountId, promptId], map: "intelligenceAccess_account_prompt_unique")
  @@map("intelligenceAccess")
}

model IntelligenceLog {
  id           BigInt  @id @default(autoincrement())
  accessId     BigInt  @map("access_id")
  query        String? @db.Text
  response     String? @db.Text
  context      String? @db.Text
  modal        String? @db.Text
  currency     String? @db.Text
  cost         Float?
  inputTokens  BigInt? @map("inputTokens")
  outputTokens BigInt? @map("outputTokens")
  balance      Float?

  @@map("intelligenceLog")
}
